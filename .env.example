# Frontend storage mode: local (default) or remote
VITE_STORAGE_MODE=local

# Notes Hub API base URL (required when VITE_STORAGE_MODE=remote)
# Dev with API on port 3001: leave empty and use Vite proxy (/api → localhost:3001)
# VITE_API_BASE_URL=http://localhost:3001
# Production: https://notes-hub-api.onrender.com
VITE_API_BASE_URL=

# Bearer token that identifies your workspace (must match API WORKSPACE_TOKEN)
VITE_WORKSPACE_TOKEN=
