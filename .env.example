# Frontend storage mode: local (default) or remote
VITE_STORAGE_MODE=local

# Notes Hub API base URL (when VITE_STORAGE_MODE=remote)
# Vercel production: leave empty — frontend and API share the same domain (/api/...)
# Local with Vercel dev: leave empty (vercel dev serves both)
# Local with Express fallback: leave empty and use Vite proxy (/api → localhost:3001)
# VITE_API_BASE_URL=http://localhost:3001
VITE_API_BASE_URL=

# Bearer token (must match WORKSPACE_TOKEN on the API)
VITE_WORKSPACE_TOKEN=

# --- Vercel API (server-side, set in Vercel dashboard — not VITE_*) ---
# WORKSPACE_TOKEN=
# UPSTASH_REDIS_REST_URL=   # auto-set via Upstash Redis integration
# UPSTASH_REDIS_REST_TOKEN= # auto-set via Upstash Redis integration
# UNSPLASH_ACCESS_KEY=      # cover image search (unsplash.com/developers)
# BLOB_READ_WRITE_TOKEN=    # auto-set via Vercel Blob store
